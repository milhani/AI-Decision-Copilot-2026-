PORT=3001

# API проекта (тот же ref, что во фронте)
SUPABASE_URL=https://ahwleoxlhbiwyjouovan.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Dashboard → Settings → API → JWT Secret (локальная проверка токена без 70s таймаута)
SUPABASE_JWT_SECRET=your-jwt-secret

# Только на сервере! Dashboard → Settings → API → service_role → Reveal
# Никогда не добавляйте в VITE_* и не коммитьте в git
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Кэш bundle в памяти (мс). 0 = без TTL, сброс только при изменениях или рестарте сервера
CACHE_TTL_MS=0

# Логи: LOG_DB=1 — все подзапросы к Supabase; LOG_STACK=1 — stack trace при ошибках
# LOG_DB=1

# DATABASE_URL больше не нужен — бэкенд ходит в Supabase по HTTPS (порт 443)

# AI (DeepSeek — OpenAI-совместимый API, ключ: https://platform.deepseek.com/api_keys)
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-...
AI_MODEL=deepseek-v4-flash
# AI_BASE_URL=https://api.deepseek.com

# Альтернатива: OpenAI
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
